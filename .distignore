# Files EXCLUDED from the WordPress.org release. Consumed by rsync --exclude-from.
# Leading "/" ANCHORS to repo root: excludes ONLY top-level dev cruft and never
# reaches into the committed runtime vendor tree (admin/vendor) or the shipped
# composer autoloaders (/vendor with pear/net_dns2, /vendor_prefixed with the
# scoped geo libraries) — all of which MUST ship. The two bundled
# classes/db-providers/*/vendor trees were removed in 1.4.0 (replaced by the
# scoped composer dependencies). NEVER add a bare "vendor" line. "/dist" is
# required (prevents rsync self-recursion).

# --- Version control / CI ---
/.git
/.gitignore
/.gitattributes
/.github
/.distignore

# --- Distribution + wp.org marketing assets (assets live in SVN /assets) ---
/.wordpress-org
/dist

# --- Dev / test tooling (top-level only) ---
/scripts
/tests
/bin
/scoper.inc.php
/node_modules
/package.json
/package-lock.json
/admin/src
/webpack.config.js
/composer.json
/composer.lock
/phpcs.xml
/phpcs.xml.dist
/phpunit.xml
/phpunit.xml.dist
/.phpunit.result.cache
/.travis.yml
/.editorconfig

# --- Dev docs (readme.txt / changelog.txt / license.txt still ship) ---
/README.md
/CHANGELOG.md
/CONTRIBUTING.md

# --- IDE / OS / temp (unanchored) ---
.idea
.vscode
*.code-workspace
.DS_Store
Thumbs.db
_tmp

# Node / build tooling (WS2). The compiled admin/build/ output IS committed
# (shipped to wp.org, since there is no CI build step); only source deps here.
/node_modules/
/dist/
npm-debug.log*

# Composer runtime deps (regenerated by `composer install`; ship in the zip).
# composer.lock IS committed for reproducible builds. vendor_prefixed/ is
# self-gitignored via its own generated .gitignore (only that file is tracked).
/vendor/

# PHPUnit run cache (generated by `composer test`).
/.phpunit.result.cache
